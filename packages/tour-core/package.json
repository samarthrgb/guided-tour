{
  "name": "@guided-tour-s4marth/core",
  "version": "0.1.1",
  "description": "Framework-light guided tour runtime",
  "license": "MIT",
  "author": "DataGenie",
  "keywords": ["guided-tour", "onboarding", "product-tour", "driver.js"],
  "repository": { "type": "git", "url": "https://github.com/samarthrgb/guided-tour", "directory": "packages/tour-core" },
  "publishConfig": { "access": "public" },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "driver.js": "^1.3.1",
    "semver": "^7.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/semver": "^7.5.8",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
